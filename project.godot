[layer_names]

3d_physics/layer_1="Player"
3d_physics/layer_2="World"
3d_physics/layer_3="Projectile"
3d_physics/layer_4="NPC"

[physics]

common/physics_ticks_per_second=120
3d/default_gravity=9.81
3d/layer_4=""
3d/quality/msaa_2d=2
3d/quality/screen_space_aa=0
3d/quality/use_taa=true

[rendering]

textures/vram_compression/import_etc2_astc=true
textures/default_filters/anisotropic_filtering_level=1
anti_aliasing/quality/msaa_2d=1
anti_aliasing/quality/msaa_3d=1
anti_aliasing/quality/screen_space_aa=1
